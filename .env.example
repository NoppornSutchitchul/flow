# Frontend (Vite dev server — optional; defaults work for local dev)
# VITE_API_URL=

# Backend database
# Local dev (default): omit DATABASE_URL → SQLite file backend/hotelops.db
# Production PostgreSQL:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/flow?sslmode=require
# Legacy alias also works:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/flow

# CORS (comma-separated origins when API and UI are on different hosts)
# CORS_ORIGINS=http://localhost:5173,https://your-domain.example

# Session / security (set in production)
# SECRET_KEY=change-me-in-production
